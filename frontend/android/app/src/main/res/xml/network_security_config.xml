<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- API is served over HTTP on AWS; allow cleartext for the backend host. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
